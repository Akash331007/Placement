# Backend Environment Configurations

# Database
# If empty, a local SQLite database (resume_analyzer.db) will be created in the current directory
DATABASE_URL=sqlite:///./resume_analyzer.db

# JWT Auth Security
# Run `openssl rand -hex 32` or type a secure random string
SECRET_KEY=9a7c81d830bfe12e6c518b5b63c76f62b8a7c29e71e4d0d3c01c05d762eef62a
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Services
# Optional: Provide Google Gemini API Key. If empty, the backend falls back to high-fidelity AI simulation mode.
GEMINI_API_KEY=

# Initial Admin Seed Data
INITIAL_ADMIN_EMAIL=admin@resumeai.com
INITIAL_ADMIN_PASSWORD=AdminSecurePass123!
